{
  "name": "hapi-typeorm",
  "version": "1.0.0",
  "description": "Hapi plugin for TypeORM.",
  "main": "lib/Plugin.js",
  "types": "lib/Plugin.d.ts",
  "scripts": {
    "prepublishOnly": "npm run lint && npm test && npm run build",
    "build": "tsc src/Plugin.ts -d -m 'commonjs' -t 'es2017' --outDir lib",
    "lint": "oxlint --fix",
    "test": "jest"
  },
  "keywords": [
    "hapi",
    "typeorm",
    "orm",
    "plugin"
  ],
  "author": "Rodrigo Saboya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qogni/hapi-typeorm.git"
  },
  "bugs": {
    "url": "https://github.com/qogni/hapi-typeorm/issues"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@hapi/hapi": "^21.3.3",
    "@types/jest": "^29.5.12",
    "@types/joi": "^17.2.3",
    "@types/node": "^20.11.20",
    "better-sqlite3": "^12.6.2",
    "jest": "^29.7.0",
    "oxlint": "^1.49.0",
    "ts-jest": "^29.1.2",
    "typeorm": "^0.3.20",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typeorm": "^0.3.0"
  },
  "resolutions": {
    "node-gyp": "^8"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/**/*.{ts,js}"
    ],
    "coverageReporters": [
      "text"
    ],
    "transform": {
      "^.+\\.tsx?$": "ts-jest"
    },
    "testRegex": "/test/.*?\\.spec\\.ts$",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  }
}
